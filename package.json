{
  "name": "@softwarestartups/patentscope",
  "version": "2.0.0",
  "description": "MCP server for searching Google Patents via SerpApi",
  "main": "build/index.js",
  "type": "module",
  "bin": {
    "patentscope": "build/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "bun run build/index.js",
    "dev": "tsc -w & bun run --watch build/index.js",
    "test": "bun run test:unit && bun run test:integration",
    "test:unit": "bun test ./tests/unit --timeout 10000",
    "test:unit:watch": "bun test --watch 'tests/unit/**/*.test.ts' --timeout 10000",
    "test:integration": "bun test ./tests/integration-mocked-api.test.ts --timeout 30000",
    "test:e2e": "LOG_LEVEL=error bun test ./tests/e2e-real-api.test.ts --timeout 120000",
    "test:all": "bun test ./tests/unit ./tests/integration-mocked-api.test.ts --timeout 30000",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "typecheck": "tsc --noEmit -p tsconfig.eslint.json"
  },
  "keywords": [
    "mcp",
    "serpapi",
    "google patents"
  ],
  "author": "SoftwareStartups (https://softwarestartups.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SoftwareStartups/patentscope.git"
  },
  "homepage": "https://github.com/SoftwareStartups/patentscope#readme",
  "bugs": {
    "url": "https://github.com/SoftwareStartups/patentscope/issues"
  },
  "files": [
    "README.md",
    "LICENSE",
    "package.json",
    "build/"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.8.0",
    "clerc": "1.3.1",
    "dotenv": "^16.4.5",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "bun-types": "^1.3.10",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "express": "^5.1.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  }
}
